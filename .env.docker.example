# Docker Compose example env for Windows + Docker Desktop

POSTGRES_USER=openmanus
POSTGRES_PASSWORD=openmanus
POSTGRES_DB=openmanus
POSTGRES_PORT=5432

BFF_DATABASE_URL=postgresql://openmanus:openmanus@postgres:5432/openmanus
RAG_DATABASE_URL=postgresql://openmanus:openmanus@postgres:5432/openmanus

LOG_DIR=/app/OpenManus/logs/app
LOG_ROTATION=20 MB
LOG_RETENTION=14 days
LOG_COMPRESSION=zip
